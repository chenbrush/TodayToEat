<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.TodayToEat" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>

        <item name="colorPrimary">@color/darkGray</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryVariant">@color/darkPressGray</item>

        <item name="android:windowBackground">@color/black</item>

        <item name="materialAlertDialogTheme">@style/MyAlertDialog.Dark</item>

        <item name="colorSurface">@color/darkGray</item>
        <item name="colorOutline">@color/transparent</item>

    </style>

    <style name="MyAlertDialog.Dark" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorPrimary">@color/title_color</item>
        <item name="android:textColor">@color/title_color</item>
    </style>

    <color name="title_color">#ffffff</color>
</resources>