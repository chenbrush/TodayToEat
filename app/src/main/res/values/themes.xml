<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.TodayToEat" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>

        <item name="colorPrimary">@color/white</item>
        <item name="colorOnPrimary">@color/black</item>

        <item name="android:windowBackground">@color/gray</item>

        <item name="materialAlertDialogTheme">@style/MyAlertDialog.Light</item>

        <item name="colorSurface">@color/white</item>
        <item name="colorOutline">@color/transparent</item>
        <item name="colorPrimaryVariant">@color/middleGray</item>

    </style>

    <style name="MyAlertDialog.Light" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorPrimary">@color/black</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:background">@color/white</item>
    </style>

    <color name="title_color">#000000</color>
</resources>